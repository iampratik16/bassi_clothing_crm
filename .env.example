# ============================================================
# Bassi Clothing — AI Marketing Skills Toolkit
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- OpenAI (for AI-powered email writing & content generation) ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- SMTP (for sending emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@bassiclothing.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@bassiclothing.com
SENDER_NAME=Bassi Clothing

# --- Apollo.io (optional, for lead enrichment) ---
APOLLO_API_KEY=your_apollo_api_key_here

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
SECRET_KEY=change-this-to-a-random-string

# --- Email Safety ---
# Max emails per day (for domain warmup, start low)
MAX_EMAILS_PER_DAY=30
# Delay between emails in seconds
EMAIL_DELAY_SECONDS=60
# Set to true for testing (emails logged but not sent)
DRY_RUN=true
